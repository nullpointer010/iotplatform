# Docker network (must match what `make bootstrap` creates)
NETWORK_NAME=iot-net

# CrateDB
CRATE_HEAP_SIZE=2g
CRATEDB_PORT=5433
ADMIN_UI_PORT=4200

# QuantumLeap → CrateDB
CRATE_HOST=cratedb
CRATE_PORT=4200
LOGLEVEL=INFO
USE_GEOCODING=false
CACHE_QUERIES=true
WQ_MAX_RETRIES=5

# PostgreSQL
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=iot_password
POSTGRES_DB=iot_database

# API
API_PORT=80
API_PREFIX=/api/v1

# FIWARE multi-tenancy headers used by the API when talking to Orion / QuantumLeap
FIWARE_SERVICE=iot
FIWARE_SERVICEPATH=/
