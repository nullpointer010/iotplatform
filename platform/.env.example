# Docker network (must match what `make bootstrap` creates)
NETWORK_NAME=iot-net

# CrateDB
CRATE_HEAP_SIZE=2g
CRATEDB_PORT=5433
ADMIN_UI_PORT=4200

# QuantumLeap → CrateDB
CRATE_HOST=cratedb
CRATE_PORT=4200
LOGLEVEL=INFO
USE_GEOCODING=false
CACHE_QUERIES=true
WQ_MAX_RETRIES=5

# PostgreSQL
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=iot_password
POSTGRES_DB=iot_database

# API
API_PORT=80
API_PREFIX=/api/v1

# FIWARE multi-tenancy headers used by the API when talking to Orion / QuantumLeap
FIWARE_SERVICE=iot
FIWARE_SERVICEPATH=/

# QuantumLeap (telemetry time-series store)
QUANTUMLEAP_URL=http://quantumleap:8668

# Maintenance store (PostgreSQL). The compose file builds this from
# POSTGRES_USER/PASSWORD/DB above; this entry is only for local docs.
DATABASE_URL=postgresql+asyncpg://iot_user:iot_password@postgres:5432/iot_database

# ─── Keycloak (ticket 0013) ──────────────────────────────────────────
# Admin UI: http://localhost:${KEYCLOAK_HTTP_PORT}
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin
KEYCLOAK_HTTP_PORT=8081

# Keycloak's own Postgres (separate from the iot-platform Postgres above).
# Internal-only — no host port published.
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-kcdb
KEYCLOAK_DB_NAME=keycloak

# ─── oauth2-proxy (ticket 0013) ──────────────────────────────────────
# Authenticated entry point: http://localhost:${OAUTH2_PROXY_PORT}
OAUTH2_PROXY_PORT=4180
OAUTH2_PROXY_CLIENT_ID=iot-web
# Must match the `iot-web` client secret in platform/config/keycloak/realm-iot.json.
OAUTH2_PROXY_CLIENT_SECRET=dev-iot-web-secret
# 32-byte base64; generate with: make secrets-keycloak
OAUTH2_PROXY_COOKIE_SECRET=
# Where the host-side `npm run dev` listens. host.docker.internal is
# resolved via the extra_hosts entry in the compose file.
OAUTH2_PROXY_UPSTREAM=http://host.docker.internal:3000
